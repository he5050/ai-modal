{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIModal",
  "version": "0.5.0",
  "identifier": "com.aimodal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "sql": {
      "preload": ["sqlite:state.db"]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "theme": "Dark"
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": true,
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": { "minimumSystemVersion": "12.0" }
  }
}
