{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capability for local rule file management.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-exists",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/.*" },
        { "path": "$HOME/.*/**" },
        { "path": "$HOME/.*/**/*" }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/.*" },
        { "path": "$HOME/.*/**" },
        { "path": "$HOME/.*/**/*" }
      ]
    },
    "opener:allow-open-url",
    "opener:allow-default-urls"
  ]
}
