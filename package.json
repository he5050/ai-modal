{
	"name": "ai-modal",
	"version": "0.3.2",
	"description": "AIModal - OpenAI 兼容接口检测与管理工具",
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"test": "vitest run",
		"tauri": "tauri",
		"tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
		"tauri:build": "tauri build",
		"tauri:build:mac-arm64": "APPLE_SIGNING_IDENTITY=- tauri build --target aarch64-apple-darwin",
		"tauri:build:mac-x64": "APPLE_SIGNING_IDENTITY=- tauri build --target x86_64-apple-darwin",
		"release": "release-it"
	},
	"devDependencies": {
		"@release-it/conventional-changelog": "^10.0.6",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/animejs": "^3.1.13",
		"@types/node": "^20.14.0",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.19",
		"jsdom": "^29.0.2",
		"postcss": "^8.4.38",
		"release-it": "^19.2.4",
		"tailwindcss": "^3.4.4",
		"typescript": "^5.4.5",
		"vite": "^5.3.1",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/lang-yaml": "^6.1.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/legacy-modes": "^6.5.2",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.40.0",
		"@lezer/highlight": "^1.2.3",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"@tauri-apps/plugin-sql": "^2.3.2",
		"@uiw/react-codemirror": "^4.25.9",
		"animejs": "^4.3.6",
		"lucide-react": "^1.7.0",
		"prettier": "^3.8.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"smol-toml": "^1.6.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
